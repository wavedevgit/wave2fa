{
    "name": "wave2fa",
    "version": "0.0.6",
    "main": "src/main.ts",
    "type": "module",
    "scripts": {
        "dev": "node --enable-source-maps dist/bundle.cjs --demo",
        "test": "node --enable-source-maps dist/bundle.cjs --demo",
        "build": "rspack build",
        "build:dev": "rspack build",
        "build:binary:linux": "bash ./scripts/build_binaries.sh linux-x64",
        "build:binary:linux:arm64": "bash ./script/build_binaries.sh linux-arm64",
        "build:binary:mac": "bash ./script/build_binaries.sh darwin-x64",
        "build:binary:mac:arm64": "bash ./script/build_binaries.sh darwin-arm64",
        "build:binary:win": "bash ./script/build_binaries.sh windows-x64",
        "build:binary:win:arm64": "bash ./script/build_binaries.sh windows-arm64",
        "build:binary:aix:ppc64": "bash ./script/build_binaries.sh aix-ppc64",
        "lint": "tsc --noEmit",
        "postinstall": "patch-package"
    },
    "bin": {
        "wave2fa": "./dist/bundle.js"
    },
