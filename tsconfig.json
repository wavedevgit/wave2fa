{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "./src",
        "outDir": "./dist",
        "allowImportingTsExtensions": true,

        "allowJs": true,
        "checkJs": true,
        "noEmit": true,

        "strict": true,

        "types": ["node"],

        "sourceMap": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*"]
}
